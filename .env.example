# ==========================================================
# Smart Home AI Platform - Root Environment Example
# Author: Abdulaziz AlAmawi (sole owner & developer)
# Copy to .env and adjust for your environment
#
# NOTE: Ports are intentionally chosen to NOT collide with other local
# projects (e.g. StudentCareer on 3000/8000):
#   Frontend 3001 | Backend 4010 | AI Engine 8010 | Postgres host 5433
# ==========================================================

# ---- PostgreSQL ----
POSTGRES_USER=shai
POSTGRES_PASSWORD=shai_secret_change_me
POSTGRES_DB=smart_home_ai
# Host-published port (container still listens internally on 5432)
POSTGRES_PORT=5433

# ---- Backend ----
BACKEND_PORT=4010
DATABASE_URL=postgresql://shai:shai_secret_change_me@postgres:5432/smart_home_ai?schema=public
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AI_ENGINE_URL=http://ai-engine:8010
CORS_ORIGIN=http://localhost:3001

# ---- AI Engine ----
AI_ENGINE_PORT=8010
MODEL_DIR=/app/models

# ---- Frontend ----
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:4010/api/v1
