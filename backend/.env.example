NODE_ENV=development
# App port (4010 avoids clashing with other local projects e.g. StudentCareer on 8000)
PORT=4010

# PostgreSQL connection string (host port 5433 to avoid clashing with other DBs)
DATABASE_URL=postgresql://shai:shai_secret_change_me@localhost:5433/smart_home_ai?schema=public

# JWT secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI engine
AI_ENGINE_URL=http://localhost:8010

# CORS (comma separated)
CORS_ORIGIN=http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
