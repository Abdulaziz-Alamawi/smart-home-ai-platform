# =====================================================================
# Smart Home AI Platform - Backend PRODUCTION environment
# Author: Abdulaziz AlAmawi
# Copy to .env and replace every secret before deploying.
# =====================================================================

NODE_ENV=production
PORT=4010

# Managed PostgreSQL connection string (Railway/Supabase/RDS/etc.)
# Always require SSL in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/smart_home_ai?schema=public&sslmode=require

# Generate with: openssl rand -hex 32  (use DIFFERENT values for each)
JWT_ACCESS_SECRET=__REPLACE_WITH_64_CHAR_RANDOM_HEX__
JWT_REFRESH_SECRET=__REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal URL of the AI engine service
AI_ENGINE_URL=https://ai-engine.internal.example.com

# Public origin(s) of the frontend (comma separated, no trailing slash)
CORS_ORIGIN=https://app.example.com

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
